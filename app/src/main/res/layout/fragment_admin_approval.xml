<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Admin Panel"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"/>

            <ImageButton
                android:id="@+id/reloadBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_popup_sync"
                android:background="@android:color/transparent"
                android:tint="@color/brand_primary"/>
        </LinearLayout>
        
        <EditText
            android:id="@+id/userSearchBar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:hint="🔍  Search users by name or email..."
            android:textColorHint="#888888"
            android:textColor="#333333"
            android:inputType="text"
            android:background="@drawable/card_bg"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"/>

        <!-- PENDING APPROVALS SECTION -->
        <TextView
            android:id="@+id/pendingHeaderTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending Approvals (0)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPendingUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp"/>

        <!-- APPROVED USERS SECTION -->
        <TextView
            android:id="@+id/approvedHeaderTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Users (0)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerApprovedUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
