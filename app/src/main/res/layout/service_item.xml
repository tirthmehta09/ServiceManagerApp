<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/serviceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header Row: Service ID + Status Badge -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/serviceIdTxt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Service ID"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/brand_primary"/>

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Status"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/status_badge_rounded"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Customer Name -->
        <TextView
            android:id="@+id/customerTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customer"
            android:textSize="15sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- Phone (clickable) -->
        <TextView
            android:id="@+id/phoneTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📞 Phone"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="6dp"/>

        <!-- Machine & Issue -->
        <TextView
            android:id="@+id/machineTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 Machine"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/issueTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Issue"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="8dp"/>

        <!-- Location (clickable → Maps) -->
        <TextView
            android:id="@+id/locationTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Location"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"/>

        <!-- Staff assigned -->
        <TextView
            android:id="@+id/staffTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👷 Staff : Not Assigned"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <!-- Closed By Text -->
        <TextView
            android:id="@+id/closedByTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Closed By : "
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:visibility="gone"/>

        <!-- Date -->
        <TextView
            android:id="@+id/dateTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🕒 Date"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/assignStaffBtn"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🧑‍🔧 Assign Staff"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <!-- Action Buttons Row 1 -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Staff: Start Service -->
            <Button
                android:id="@+id/startServiceBtn"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="▶ Start Service"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#388E3C"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

            <!-- Staff: Not Going -->
            <Button
                android:id="@+id/notGoingBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="✖ Not Going"
                android:textSize="13sp"
                app:strokeColor="#D32F2F"
                android:textColor="#D32F2F"
                android:layout_marginStart="6dp"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Update Status Spinner + Button -->
        <Spinner
            android:id="@+id/statusSpinner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="12dp"
            android:visibility="gone"
            android:overlapAnchor="false"
            android:spinnerMode="dropdown"/>

        <Button
            android:id="@+id/updateStatusBtn"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Update Status"
            android:backgroundTint="#0288D1"
            app:cornerRadius="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <!-- Photo Buttons Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/uploadCompletionBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="📹 Upload Completion Video"
                android:textSize="13sp"
                app:strokeColor="#1565C0"
                android:textColor="#1565C0"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Admin Photo View Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/viewCompletionBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="▶ View Completion Video"
                android:textSize="13sp"
                app:strokeColor="#2E7D32"
                android:textColor="#2E7D32"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Video / Close Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/videoBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="▶ Initial Video"
                android:textSize="13sp"
                app:strokeColor="#424242"
                android:textColor="#424242"
                app:cornerRadius="12dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/closeServiceBtn"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="✔ Close"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"
                android:backgroundTint="#D32F2F"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>